---
boruta_namespace: "boruta-staging"
boruta_name: "boruta"
boruta_ingress_class: "boruta"
boruta_ingress_http_node_port: "30080"
boruta_ingress_https_node_port: "30443"
boruta_libcluster_namespace: "*"
boruta_libcluster_selector: "identity_platform=boruta"
boruta_release_cookie: "cookie"

boruta_postgres_name: "postgres"
boruta_postgres_user: "postgres"
boruta_postgres_password: "3GxM0PgMMw"
boruta_postgres_database: "boruta"

boruta_configuration_name: "boruta-static-configuration"
boruta_configuration_path: "/app/config/static-configuration.yml"
boruta_admin_name: "boruta-admin"
boruta_admin_host: "admin.boruta.patatoid.fr"
boruta_admin_port: "8081"
boruta_admin_base_url: "https://admin.boruta.patatoid.fr"
boruta_admin_oauth_client_id: "00000000-0000-0000-0000-000000000001"
boruta_auth_namespace: "{{ boruta_namespace }}"
boruta_auth_name: "boruta-auth"
boruta_oauth_environment_name: "{{ boruta_name }}-oauth-env"
boruta_oauth_scheme: "http"
boruta_oauth_host: "auth.boruta.local"
boruta_oauth_port: "8080"
boruta_oauth_base_url: "{{ boruta_oauth_scheme }}://{{ boruta_oauth_host }}:{{ boruta_ingress_http_node_port }}"

boruta_ingress_controller_name: "boruta-ingress-controller"
boruta_ingress_service_account: "boruta-ingress-controller"
boruta_ingress_service_name: "boruta-ingress-controller"
boruta_ingress_tls_dns_names:
  - "{{ boruta_oauth_host }}"
  - "{{ boruta_admin_host }}"
  - "{{ gateway_host }}"
cert_manager_namespace: "cert-manager"
letsencrypt_cluster_issuer_name: "letsencrypt-prod"
letsencrypt_email: "admin@boruta.patatoid.fr"
letsencrypt_server: "https://acme-v02.api.letsencrypt.org/directory"
boruta_gateway_image: "ghcr.io/malach-it/boruta-gateway:kubernetes-ingress-controller.alpha.10"
boruta_admin_image: "ghcr.io/malach-it/boruta-admin:0.10.0"
boruta_auth_image: "ghcr.io/malach-it/boruta-auth:0.10.0"
boruta_kagome_image: "ghcr.io/malach-it/kagome:kubernetes-ingress-controller.alpha.4"
boruta_kagome_image_pull_policy: "Always"

boruta_ingress_watch_namespace: "{{ ingress_watch_namespace | default('*') }}"
boruta_ingress_node_name: "global"
boruta_ingress_replicas: "2"
boruta_ingress_poll_interval: "10000"
boruta_gateway_acceptors: "32"
boruta_gateway_http_enabled: "true"
boruta_gateway_http_port: "5000"
boruta_gateway_https_enabled: "true"
boruta_gateway_https_port: "5443"
boruta_gateway_certificate_mount_path: "/app/lib/boruta_gateway-0.1.0/priv/ssl"
boruta_gateway_mounted_certificate_dir: "/var/run/boruta/gateway-tls"
boruta_gateway_mounted_certificate_path: "{{ boruta_gateway_mounted_certificate_dir }}/tls.crt"
boruta_gateway_mounted_private_key_path: "{{ boruta_gateway_mounted_certificate_dir }}/tls.key"
boruta_gateway_tls_secret_name: "boruta-ingress-tls"
boruta_postgres_image: "postgres:16-alpine"
boruta_postgres_host: "{{ boruta_postgres_name }}"
boruta_postgres_storage_size: "5Gi"
boruta_logs_pvc_name: "{{ boruta_name }}-logs"
boruta_logs_storage_class: "standard-rwo"
boruta_logs_access_mode: "ReadWriteOnce"
boruta_logs_storage_size: "5Gi"

kagome_namespace: "{{ boruta_namespace }}"
kagome_configuration_name: "kagome-configuration"
kagome_environment_name: "kagome-env"
kagome_secret_name: "kagome-secrets"
kagome_mtls_enabled: "true"
