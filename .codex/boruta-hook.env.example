# Copy to a local shell profile or env file and replace placeholders.
# Do not commit real client secrets, private keys, or session state.

BORUTA_OAUTH_BASE_URL=http://localhost:8080

# OAuth client used by scripts/agent_session_authorize.py for code-chain tokens.
BORUTA_CODEX_HOOK_CLIENT_ID=00000000-0000-0000-0000-000000000001
BORUTA_CODEX_HOOK_CLIENT_SECRET=replace-with-client-secret
BORUTA_AGENT_SESSION_GRANT_TYPE=code_chain
BORUTA_CODEX_HOOK_TOKEN_TARGET=http://localhost:8080/oauth/token
BORUTA_CODEX_HOOK_TOKEN_TIMEOUT=5

# Local key and authorization-code chain state. These files contain sensitive material.
BORUTA_CODEX_HOOK_KEYS_DIR=~/.boruta/keys
BORUTA_AGENT_SESSION_STATE_FILE=~/.boruta/session-code-chain.json
BORUTA_AGENT_CREDENTIALS_DIR=~/.boruta/agent_credentials

# Browser authorization used by .codex/hooks/boruta_agent_session_hook.py.
BORUTA_CODEX_HOOK_BROWSER_CLIENT_ID=00000000-0000-0000-0000-000000000001
BORUTA_CODEX_HOOK_BROWSER_REDIRECT_URI=http://127.0.0.1:8765/oauth-callback
BORUTA_CODEX_HOOK_BROWSER_CALLBACK_HOST=127.0.0.1
BORUTA_CODEX_HOOK_BROWSER_TIMEOUT=300
BORUTA_CODEX_HOOK_OPEN_BROWSER=true
BORUTA_CODEX_HOOK_VERIFIABLE_PRESENTATION_URL=http://localhost:8080/oauth/authorize

# Authorization behavior.
BORUTA_CODEX_HOOK_AUTHORIZE_ALL=true
BORUTA_CODEX_HOOK_BROWSER_AUTH=false
BORUTA_CODEX_HOOK_BROWSER_AUTH_FOR_ALL=false
BORUTA_CODEX_HOOK_ENFORCE=true
BORUTA_CODEX_HOOK_STATUS=true
BORUTA_CODEX_HOOK_STATUS_STYLE=panel
BORUTA_CODEX_HOOK_STATUS_CONTEXT=false
BORUTA_CODEX_HOOK_VERBOSE=false
BORUTA_CODEX_HOOK_DRY_RUN=false

# Session and chain behavior.
BORUTA_CODEX_HOOK_RESET_ON_USER_PROMPT=true
BORUTA_CODEX_HOOK_RESET_ON_SESSION_START=false
BORUTA_CODEX_HOOK_SESSION_FILE=~/.boruta/codex-hook-session.json
BORUTA_CODEX_HOOK_SCOPE_SESSION_FILE=~/.boruta/codex-hook-scopes-session.json
BORUTA_CODEX_HOOK_DOCKER_COMPOSE_SESSION_FILE=~/.boruta/codex-hook-docker-compose-session.json
BORUTA_CODEX_HOOK_WALLET_SERVER_SESSION_FILE=~/.boruta/codex-hook-wallet-server-session.json
BORUTA_CODEX_HOOK_WALLET_SERVER_LOG_FILE=~/.boruta/codex-hook-wallet-server.log

# Optional defaults. Leave unset to derive actor and scope from Codex hook events.
# BORUTA_CODEX_HOOK_ACTOR=user:codex-user
# BORUTA_CODEX_HOOK_ACTOR_UserPromptSubmit=user:codex-user
# BORUTA_CODEX_HOOK_ACTOR_PreToolUse=assistant:codex
# BORUTA_CODEX_HOOK_SCOPE=codex:event:userpromptsubmit codex:prompt:submit

# Optional local wallet responder implemented by .codex/hooks/boruta_wallet_hook.py.
# The SessionStart hook starts it once per Codex session, the authorization hook
# falls back to UserPromptSubmit if needed, and the Stop hook shuts it down.
BORUTA_CODEX_HOOK_WALLET_SERVER=false
BORUTA_CODEX_HOOK_WALLET_SERVER_URL=http://127.0.0.1:8766/agent/wallet
BORUTA_CODEX_HOOK_WALLET_ACTOR=user:codex-wallet
# Internal child-process mode used by the hook-managed wallet responder.
BORUTA_CODEX_HOOK_SERVE_WALLET_SERVER=false
# BORUTA_CODEX_HOOK_REPO_ROOT=/absolute/path/to/boruta-server

# Optional local service startup. .codex/hooks/boruta_session_start_hook.py starts
# it once per Codex session; the authorization hook falls back to UserPromptSubmit
# if needed. The default command is "docker compose up -d".
BORUTA_CODEX_HOOK_DOCKER_COMPOSE_START=true
BORUTA_CODEX_HOOK_DOCKER_COMPOSE_COMMAND="docker compose up -d"
BORUTA_CODEX_HOOK_DOCKER_COMPOSE_TIMEOUT=300
